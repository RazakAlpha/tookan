# ─── DELIVERY PLUGIN — ENVIRONMENT CONFIG ─────────────
# Copy this file to .env in your project root
# Works immediately with mock providers (no API keys needed)
# Switch to real providers when ready for production

# ─── Server ───────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Address Provider ─────────────────────────────────
# Start with "mock" for development (no API key needed)
# Switch to "google" or "mapbox" for production
ADDRESS_PROVIDER=mock

# Google Maps / Places (only needed if ADDRESS_PROVIDER=google)
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=

# Mapbox (only needed if ADDRESS_PROVIDER=mapbox)
MAPBOX_ACCESS_TOKEN=

# ─── Address Autocomplete ─────────────────────────────
ADDRESS_AUTOCOMPLETE_MIN_CHARS=3
ADDRESS_AUTOCOMPLETE_DEBOUNCE_MS=300
ADDRESS_AUTOCOMPLETE_MAX_RESULTS=5
ADDRESS_AUTOCOMPLETE_COUNTRY_BIAS=us

# ─── Service Area ─────────────────────────────────────
# Options: radius | polygon | disabled
ADDRESS_SERVICE_AREA_MODE=radius

# ─── Delivery Provider ────────────────────────────────
# Start with "mock" for development (no API key needed)
# Switch to "tookan" for production
DELIVERY_PROVIDER=mock

# ─── Tookan Config (only needed if DELIVERY_PROVIDER=tookan) ──
TOOKAN_API_KEY=
TOOKAN_BASE_URL=https://api.tookanapp.com/v2

# Timezone: UTC offset in minutes
# Convert: hours_ahead_of_UTC × -60
# EST (UTC-5)   = -300
# CST (UTC-6)   = -360
# PST (UTC-8)   = 480
# IST (UTC+5:30)= -330
# SGT (UTC+8)   = -480
# GMT (UTC+0)   = 0
TOOKAN_TIMEZONE=-300

# Auto-assign to nearest available agent (set 0 to disable)
TOOKAN_AUTO_ASSIGNMENT=1

# Push-notify agent on assignment (1=yes, 0=no)
TOOKAN_NOTIFY=1

# Use geofence for auto-assignment (1=yes, 0=no)
TOOKAN_GEOFENCE=1

# Assign tasks to a specific team (leave blank for any team)
TOOKAN_TEAM_ID=

# Agent tags filter (comma-separated, leave blank for all agents)
TOOKAN_TAGS=

# Custom field templates (must match names in Tookan Dashboard → Settings → Templates)
TOOKAN_TEMPLATE_ID=
TOOKAN_PICKUP_TEMPLATE=
TOOKAN_DELIVERY_TEMPLATE=

# ─── Rate Limiting ────────────────────────────────────
RATE_LIMIT_AUTOCOMPLETE_WINDOW_MS=60000
RATE_LIMIT_AUTOCOMPLETE_MAX=60
RATE_LIMIT_DISPATCH_WINDOW_MS=60000
RATE_LIMIT_DISPATCH_MAX=20
